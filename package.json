{
	"name": "n8n-nodes-arco-crm",
	"version": "0.4.1",
	"packageManager": "pnpm@8.15.0",
	"description": "n8n community node for Arco CRM (Public API)",
	"license": "MIT",
	"homepage": "https://github.com/matheustelo/n8n-nodes-arco-crm",
	"keywords": [
		"n8n-community-node-package",
		"arco",
		"arco-crm",
		"crm"
	],
	"author": {
		"name": "Matheus Telo",
		"email": "matheus@grupoarco.cc"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/matheustelo/n8n-nodes-arco-crm.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": false,
		"credentials": [
			"dist/credentials/ArcoCrmApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/ArcoCrm/ArcoCrm.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.39.4",
		"prettier": "3.8.3",
		"release-it": "20.0.1",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
